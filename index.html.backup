<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>🦺 CoW Log</title>
    <meta name="theme-color" content="#0d1117">
    <link rel="manifest" href="manifest.json">
    <style>
        :root {
            --bg: #0d1117;
            --card: #161b22;
            --border: #30363d;
            --text: #e6edf3;
            --muted: #8b949e;
            --accent: #f78166;
            --green: #3fb950;
            --red: #f85149;
            --yellow: #d2991d;
            --blue: #58a6ff;
            --purple: #a371f7;
            --radius: 12px;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            padding-bottom: 100px;
            -webkit-tap-highlight-color: transparent;
            font-size: 15px;
            line-height: 1.5;
        }
        .header {
            background: var(--card);
            padding: 16px;
            position: sticky;
            top: 0;
            z-index: 100;
            border-bottom: 1px solid var(--border);
        }
        .header-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
        }
        .header h1 { font-size: 1.2rem; color: var(--accent); }
        .header .date { font-size: 0.8rem; color: var(--muted); text-align: right; }
        .project-info {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
            font-size: 0.75rem;
            color: var(--muted);
        }
        .project-info .label {
            color: var(--muted);
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .project-info input, .project-info select {
            background: var(--bg);
            border: 1px solid var(--border);
            color: var(--text);
            padding: 6px 10px;
            border-radius: 6px;
            font-size: 0.75rem;
            width: 100%;
            font-family: inherit;
        }
        .stats-row {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 6px;
            padding: 12px 16px;
        }
        .stat-card {
            background: var(--card);
            padding: 12px 8px;
            border-radius: var(--radius);
            text-align: center;
            border: 1px solid var(--border);
        }
        .stat-card .count { font-size: 1.5rem; font-weight: 700; }
        .stat-card .label { font-size: 0.6rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.5px; margin-top: 2px; }
        .stat-card .count.red { color: var(--red); }
        .stat-card .count.green { color: var(--green); }
        .stat-card .count.yellow { color: var(--yellow); }
        .stat-card .count.blue { color: var(--blue); }
        .stat-card .count.purple { color: var(--purple); }
        .tabs {
            display: flex;
            gap: 4px;
            padding: 0 16px;
            margin-bottom: 12px;
            overflow-x: auto;
            scrollbar-width: none;
        }
        .tabs::-webkit-scrollbar { display: none; }
        .tab {
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 0.75rem;
            white-space: nowrap;
            border: 1px solid var(--border);
            background: transparent;
            color: var(--muted);
            cursor: pointer;
            font-weight: 500;
        }
        .tab.active { background: var(--accent); border-color: var(--accent); color: #0d1117; font-weight: 600; }
        .content { padding: 0 16px; }
        .panel { display: none; }
        .panel.active { display: block; }
        .entry-card {
            background: var(--card);
            border-radius: var(--radius);
            padding: 14px;
            margin-bottom: 10px;
            border: 1px solid var(--border);
            border-left: 4px solid var(--border);
        }
        .entry-card.diary-card { border-left-color: var(--blue); }
        .entry-card.inspection-card { border-left-color: var(--green); }
        .entry-card.ncr-card { border-left-color: var(--red); }
        .entry-card.instruction-card { border-left-color: var(--yellow); }
        .entry-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 8px;
            gap: 8px;
        }
        .entry-title { font-weight: 600; font-size: 0.9rem; }
        .badge {
            font-size: 0.65rem;
            padding: 4px 10px;
            border-radius: 12px;
            font-weight: 600;
            white-space: nowrap;
        }
        .badge-pass { background: rgba(63,185,80,0.15); color: var(--green); }
        .badge-fail { background: rgba(248,81,73,0.15); color: var(--red); }
        .badge-open { background: rgba(248,81,73,0.15); color: var(--red); }
        .badge-closed { background: rgba(63,185,80,0.15); color: var(--green); }
        .badge-pending { background: rgba(210,153,29,0.15); color: var(--yellow); }
        .badge-info { background: rgba(88,166,255,0.15); color: var(--blue); }
        .entry-meta { font-size: 0.7rem; color: var(--muted); margin-bottom: 8px; display: flex; flex-wrap: wrap; gap: 12px; }
        .entry-desc { font-size: 0.8rem; line-height: 1.6; color: #c9d1d9; }
        .entry-section {
            background: var(--bg);
            border-radius: 8px;
            padding: 10px 12px;
            margin-top: 8px;
            font-size: 0.75rem;
        }
        .entry-section .section-label {
            font-size: 0.65rem;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 6px;
        }
        .fab {
            position: fixed;
            bottom: 24px;
            right: 24px;
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: var(--accent);
            color: #0d1117;
            border: none;
            font-size: 1.5rem;
            cursor: pointer;
            box-shadow: 0 4px 20px rgba(247,129,102,0.3);
            z-index: 200;
            font-weight: 700;
        }
        .fab:active { transform: scale(0.92); }
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.85);
            z-index: 300;
            display: flex;
            align-items: flex-end;
            animation: fadeIn 0.15s ease;
        }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        .modal {
            background: var(--card);
            width: 100%;
            border-radius: 20px 20px 0 0;
            padding: 20px;
            max-height: 88vh;
            overflow-y: auto;
            border: 1px solid var(--border);
            border-bottom: none;
        }
        .modal h2 { font-size: 1rem; margin-bottom: 16px; color: var(--accent); display: flex; align-items: center; gap: 8px; }
        .form-group { margin-bottom: 12px; }
        .form-group label {
            display: block;
            font-size: 0.7rem;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 4px;
            font-weight: 600;
        }
        .modal input, .modal textarea, .modal select {
            width: 100%;
            padding: 12px;
            border-radius: 8px;
            border: 1px solid var(--border);
            background: var(--bg);
            color: var(--text);
            font-size: 0.85rem;
            font-family: inherit;
        }
        .modal input:focus, .modal textarea:focus, .modal select:focus {
            outline: none;
            border-color: var(--accent);
        }
        .modal textarea { min-height: 90px; resize: vertical; }
        .btn-row { display: flex; gap: 10px; margin-top: 16px; flex-wrap: wrap; }
        .btn {
            padding: 12px 20px;
            border-radius: 10px;
            border: none;
            font-weight: 600;
            font-size: 0.85rem;
            cursor: pointer;
            flex: 1;
            transition: opacity 0.15s;
            min-width: 80px;
        }
        .btn:active { opacity: 0.8; }
        .btn-primary { background: var(--accent); color: #0d1117; }
        .btn-secondary { background: var(--border); color: var(--text); }
        .btn-danger { background: var(--red); color: white; }
        .btn-whatsapp { background: #25D366; color: white; }
        .btn-small { padding: 6px 12px; font-size: 0.7rem; border-radius: 6px; flex: 0; }
        .checklist-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 0;
            border-bottom: 1px solid var(--border);
            font-size: 0.8rem;
            cursor: pointer;
            flex-wrap: wrap;
        }
        .checklist-item input[type="checkbox"] { width: 20px; height: 20px; accent-color: var(--green); }
        .report-preview {
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 16px;
            font-family: 'SF Mono', 'Fira Code', monospace;
            font-size: 0.7rem;
            line-height: 1.8;
            white-space: pre-wrap;
            max-height: 60vh;
            overflow-y: auto;
            color: var(--text);
        }
        .search-bar { margin-bottom: 12px; }
        .search-bar input {
            width: 100%;
            padding: 12px 16px;
            border-radius: 10px;
            border: 1px solid var(--border);
            background: var(--card);
            color: var(--text);
            font-size: 0.85rem;
        }
        .empty-state { text-align: center; padding: 48px 20px; color: var(--muted); }
        .empty-state .icon { font-size: 3rem; margin-bottom: 12px; opacity: 0.5; }
        .toast {
            position: fixed;
            bottom: 100px;
            left: 50%;
            transform: translateX(-50%);
            background: var(--green);
            color: #0d1117;
            padding: 10px 24px;
            border-radius: 20px;
            font-weight: 600;
            font-size: 0.8rem;
            z-index: 400;
            animation: toastIn 0.3s ease;
        }
        @keyframes toastIn { from { opacity: 0; transform: translateX(-50%) translateY(20px); } to { opacity: 1; transform: translateX(-50%) translateY(0); } }

        /* MEDIA GALLERY */
        .media-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 6px;
        }
        .media-thumb {
            aspect-ratio: 1;
            background: var(--card);
            border-radius: 8px;
            border: 1px solid var(--border);
            overflow: hidden;
            position: relative;
            cursor: pointer;
        }
        .media-thumb img, .media-thumb video {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .media-thumb .placeholder {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: var(--muted);
        }
        .media-thumb .media-badge {
            position: absolute;
            bottom: 4px;
            right: 4px;
            background: rgba(0,0,0,0.7);
            color: white;
            font-size: 0.55rem;
            padding: 2px 6px;
            border-radius: 4px;
        }
        .media-viewer {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.95);
            z-index: 500;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }
        .media-viewer img, .media-viewer video {
            max-width: 95%;
            max-height: 70vh;
            border-radius: 8px;
        }
        .media-viewer .close-btn {
            position: absolute;
            top: 20px;
            right: 20px;
            background: var(--red);
            color: white;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: none;
            font-size: 1.2rem;
            cursor: pointer;
        }
        .media-viewer .media-info {
            color: var(--text);
            font-size: 0.8rem;
            margin-top: 16px;
            text-align: center;
        }

        /* CAMERA / UPLOAD BUTTONS */
        .media-actions {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
            margin-top: 8px;
        }
        .media-actions .btn {
            padding: 14px;
            text-align: center;
            font-size: 0.8rem;
        }
        .media-preview {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            margin-top: 8px;
        }
        .media-preview-item {
            width: 80px;
            height: 80px;
            border-radius: 8px;
            border: 1px solid var(--border);
            overflow: hidden;
            position: relative;
        }
        .media-preview-item img, .media-preview-item video {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .media-preview-item .remove-media {
            position: absolute;
            top: 2px;
            right: 2px;
            background: var(--red);
            color: white;
            width: 22px;
            height: 22px;
            border-radius: 50%;
            border: none;
            font-size: 0.7rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* PRINT STYLES */
        @media print {
            body { background: white; color: black; font-size: 11pt; }
            .header, .stats-row, .tabs, .fab, .btn, .search-bar, .modal-overlay, .toast { display: none !important; }
            .content { padding: 0; max-width: 100%; }
            .panel { display: block !important; }
            .panel:not(#panel-report) { display: none !important; }
            #panel-report { display: block !important; }
            .report-preview {
                background: white;
                border: none;
                color: black;
                font-family: 'Courier New', monospace;
                font-size: 10pt;
                max-height: none;
                overflow: visible;
                white-space: pre-wrap;
            }
            .entry-card { border: 1px solid #ccc; background: white; margin-bottom: 8px; page-break-inside: avoid; }
            .entry-card .badge { border: 1px solid #999; }
        }

        @media (min-width: 600px) {
            .content { max-width: 600px; margin: 0 auto; }
            .stats-row { max-width: 600px; margin: 0 auto; }
            .header { padding: 16px max(16px, calc((100% - 600px)/2)); }
        }
    </style>
</head>
<body>
    <!-- Hidden file input -->
    <input type="file" id="hiddenFileInput" accept="image/*,video/*" capture="environment" multiple style="display:none;">
    <input type="file" id="hiddenGalleryInput" accept="image/*,video/*" multiple style="display:none;">

    <!-- HEADER -->
    <div class="header">
        <div class="header-row">
            <h1>🦺 CoW Log</h1>
            <span class="date" id="currentDate"></span>
        </div>
        <div class="project-info">
            <div>
                <div class="label">Project</div>
                <input type="text" id="projectName" value="Riverside Apartments" placeholder="Project name">
            </div>
            <div>
                <div class="label">Contract No.</div>
                <input type="text" id="contractNo" value="RAP/CW/2026/001" placeholder="Contract No.">
            </div>
            <div>
                <div class="label">Contractor</div>
                <input type="text" id="contractorName" value="BuildRight Construction Ltd" placeholder="Contractor">
            </div>
            <div>
                <div class="label">Report No.</div>
                <input type="text" id="reportNo" value="COW-001" placeholder="Report No.">
            </div>
            <div style="grid-column: 1 / -1; display: grid; grid-template-columns: 1fr 1fr; gap: 8px;">
                <div>
                    <div class="label">Weather</div>
                    <select id="weatherSelect">
                        <option>☀️ Sunny & Clear</option>
                        <option>⛅ Partly Cloudy</option>
                        <option>☁️ Overcast</option>
                        <option>🌧️ Light Rain</option>
                        <option>⛈️ Heavy Rain / Storm</option>
                        <option>🌙 Night Work</option>
                    </select>
                </div>
                <div>
                    <div class="label">Temperature</div>
                    <input type="text" id="temperature" value="26°C" placeholder="Temp">
                </div>
            </div>
        </div>
    </div>

    <!-- STATS -->
    <div class="stats-row">
        <div class="stat-card"><div class="count blue" id="diaryCount">0</div><div class="label">Diary</div></div>
        <div class="stat-card"><div class="count green" id="inspectionCount">0</div><div class="label">Inspections</div></div>
        <div class="stat-card"><div class="count red" id="ncrCount">0</div><div class="label">Open NCRs</div></div>
        <div class="stat-card"><div class="count yellow" id="instructionCount">0</div><div class="label">SI</div></div>
        <div class="stat-card"><div class="count purple" id="photoCount">0</div><div class="label">Media</div></div>
    </div>

    <!-- TABS -->
    <div class="tabs">
        <button class="tab active" data-tab="diary">📔 Diary</button>
        <button class="tab" data-tab="inspections">✅ Inspections</button>
        <button class="tab" data-tab="ncr">🚨 NCRs</button>
        <button class="tab" data-tab="instructions">📋 SI</button>
        <button class="tab" data-tab="photos">📸 Media</button>
        <button class="tab" data-tab="report">📄 Report</button>
    </div>

    <!-- CONTENT -->
    <div class="content">
        <div class="panel active" id="panel-diary">
            <div class="search-bar"><input type="text" placeholder="🔍 Search diary entries..." id="diarySearch"></div>
            <div id="diaryEntries"></div>
        </div>
        <div class="panel" id="panel-inspections"><div id="inspectionEntries"></div></div>
        <div class="panel" id="panel-ncr"><div id="ncrEntries"></div></div>
        <div class="panel" id="panel-instructions"><div id="instructionEntries"></div></div>
        <div class="panel" id="panel-photos"><div id="photoGallery"></div></div>
        <div class="panel" id="panel-report"><div id="reportContent"></div></div>
    </div>

    <button class="fab" id="fabBtn">+</button>
    <div id="modalContainer"></div>
    <div id="toastContainer"></div>
    <div id="mediaViewer"></div>

    <script>
        // ============================================
        // DATA STORE
        // ============================================
        const STORAGE_KEY = 'cowlog_v3';
        const SETTINGS_KEY = 'cowlog_settings';
        const MEDIA_KEY = 'cowlog_media';

        function loadData() {
            try {
                const raw = localStorage.getItem(STORAGE_KEY);
                return raw ? JSON.parse(raw) : { diary: [], inspections: [], ncrs: [], instructions: [], photos: [], dailyReports: [] };
            } catch(e) {
                return { diary: [], inspections: [], ncrs: [], instructions: [], photos: [], dailyReports: [] };
            }
        }

        function saveData(data) { localStorage.setItem(STORAGE_KEY, JSON.stringify(data)); }

        // Media stored separately due to size
        function loadMedia() {
            try {
                const raw = localStorage.getItem(MEDIA_KEY);
                return raw ? JSON.parse(raw) : [];
            } catch(e) { return []; }
        }

        function saveMedia(media) {
            // Limit to 50 media items to avoid storage issues
            if (media.length > 50) media = media.slice(-50);
            localStorage.setItem(MEDIA_KEY, JSON.stringify(media));
        }

        function loadSettings() {
            try { const raw = localStorage.getItem(SETTINGS_KEY); return raw ? JSON.parse(raw) : {}; }
            catch(e) { return {}; }
        }

        function saveSettings(s) { localStorage.setItem(SETTINGS_KEY, JSON.stringify(s)); }

        let appData = loadData();
        let mediaStore = loadMedia();
        let settings = loadSettings();

        function genId(prefix) { return prefix + '-' + Date.now() + '-' + Math.random().toString(36).substr(2, 6); }

        function timeFormat(ts) { return new Date(ts).toLocaleString('en-KE', { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }); }
        function dateOnly(ts) { return new Date(ts).toLocaleDateString('en-KE', { year: 'numeric', month: 'short', day: 'numeric' }); }
        function getToday() { return new Date().toISOString().split('T')[0]; }

        // ============================================
        // MEDIA HANDLING
        // ============================================
        let pendingMedia = []; // For current form
        let pendingMediaForEntry = null; // For adding to existing entry

        function compressImage(dataUrl, maxWidth, quality) {
            return new Promise((resolve) => {
                const img = new Image();
                img.onload = () => {
                    const canvas = document.createElement('canvas');
                    let w = img.width, h = img.height;
                    if (w > maxWidth) { h = h * (maxWidth / w); w = maxWidth; }
                    canvas.width = w;
                    canvas.height = h;
                    const ctx = canvas.getContext('2d');
                    ctx.drawImage(img, 0, 0, w, h);
                    resolve(canvas.toDataURL('image/jpeg', quality || 0.7));
                };
                img.src = dataUrl;
            });
        }

        async function addMediaFromFile(file) {
            return new Promise((resolve) => {
                const reader = new FileReader();
                reader.onload = async (e) => {
                    let dataUrl = e.target.result;
                    let type = file.type.startsWith('video/') ? 'video' : 'image';

                    // Compress images
                    if (type === 'image' && dataUrl.length > 500000) {
                        dataUrl = await compressImage(dataUrl, 1200, 0.6);
                    }

                    // For video, limit size (take first frame or compress)
                    if (type === 'video' && dataUrl.length > 2000000) {
                        // Store as placeholder for video (actual video too large for localStorage)
                        type = 'video-large';
                    }

                    const mediaItem = {
                        id: genId('media'),
                        type: type,
                        dataUrl: type === 'video-large' ? null : dataUrl,
                        fileName: file.name,
                        fileSize: file.size,
                        timestamp: new Date().toISOString(),
                        label: ''
                    };
                    pendingMedia.push(mediaItem);
                    resolve(mediaItem);
                };
                if (file.type.startsWith('video/') && file.size > 2000000) {
                    // For large videos, just store metadata
                    resolve({
                        id: genId('media'),
                        type: 'video-large',
                        dataUrl: null,
                        fileName: file.name,
                        fileSize: file.size,
                        timestamp: new Date().toISOString(),
                        label: '(Large video — stored as reference)'
                    });
                } else {
                    reader.readAsDataURL(file);
                }
            });
        }

        function triggerCamera() {
            const input = document.getElementById('hiddenFileInput');
            input.setAttribute('capture', 'environment');
            input.click();
        }

        function triggerGallery() {
            const input = document.getElementById('hiddenGalleryInput');
            input.removeAttribute('capture');
            input.click();
        }

        function renderMediaPreview() {
            const container = document.getElementById('mediaPreviewContainer');
            if (!container) return;
            if (pendingMedia.length === 0) {
                container.innerHTML = '<p style="font-size:0.7rem;color:var(--muted);">No media added yet</p>';
                return;
            }
            container.innerHTML = pendingMedia.map((m, i) => '' +
                '<div class="media-preview-item">' +
                    (m.type === 'video' || m.type === 'video-large' ? '<div class="placeholder">🎬</div>' : '<img src="' + (m.dataUrl || '') + '" alt="media">') +
                    '<button class="remove-media" onclick="removePendingMedia(' + i + ')">✕</button>' +
                '</div>'
            ).join('');
        }

        function removePendingMedia(index) {
            pendingMedia.splice(index, 1);
            renderMediaPreview();
        }

        function savePendingMedia(entryId) {
            pendingMedia.forEach(m => {
                m.entryId = entryId;
                mediaStore.push(m);
            });
            saveMedia(mediaStore);
            const saved = [...pendingMedia];
            pendingMedia = [];
            return saved;
        }

        function viewMedia(mediaId) {
            const item = mediaStore.find(m => m.id === mediaId);
            if (!item) return;
            const viewer = document.getElementById('mediaViewer');
            viewer.innerHTML = '' +
                '<div class="media-viewer" onclick="closeMediaViewer()">' +
                    '<button class="close-btn">✕</button>' +
                    (item.type === 'video' ? '<video src="' + item.dataUrl + '" controls autoplay></video>' :
                     item.type === 'video-large' ? '<div style="color:white;text-align:center;"><div style="font-size:4rem;">🎬</div><p>Large video file</p><p style="font-size:0.8rem;">' + item.fileName + '</p></div>' :
                     '<img src="' + item.dataUrl + '" alt="' + (item.label || 'Photo') + '">') +
                    '<div class="media-info">' +
                        '<p>' + (item.label || 'Site Photo') + '</p>' +
                        '<p style="font-size:0.7rem;color:var(--muted);">' + timeFormat(item.timestamp) + '</p>' +
                        '<button class="btn btn-small btn-primary" style="margin-top:8px;" onclick="event.stopPropagation();shareMedia(\'' + mediaId + '\')">📤 Share</button>' +
                    '</div>' +
                '</div>';
        }

        function closeMediaViewer() {
            document.getElementById('mediaViewer').innerHTML = '';
        }

        async function shareMedia(mediaId) {
            const item = mediaStore.find(m => m.id === mediaId);
            if (!item) return;
            if (navigator.share && item.dataUrl) {
                try {
                    // Convert dataUrl to blob
                    const res = await fetch(item.dataUrl);
                    const blob = await res.blob();
                    const file = new File([blob], item.fileName || 'photo.jpg', { type: blob.type });
                    await navigator.share({
                        title: item.label || 'Site Photo',
                        files: [file]
                    });
                    showToast('📤 Shared!');
                } catch(e) {
                    // Fallback to WhatsApp
                    shareViaWhatsApp(item.label || 'Site Photo', item.dataUrl);
                }
            } else {
                shareViaWhatsApp(item.label || 'Site Photo', item.dataUrl);
            }
        }

        function shareMediaGallery() {
            const recentMedia = mediaStore.slice(-5);
            if (recentMedia.length === 0) {
                showToast('No media to share');
                return;
            }
            let text = '📸 Site Photos — ' + document.getElementById('projectName').value + '\n';
            text += 'Date: ' + getToday() + '\n\n';
            recentMedia.forEach((m, i) => {
                text += (i+1) + '. ' + (m.label || 'Photo') + ' — ' + timeFormat(m.timestamp) + '\n';
            });
            text += '\n— Sent via CoW Log';
            shareViaWhatsApp('Site Media', text);
        }

        // ============================================
        // TOAST
        // ============================================
        function showToast(msg) {
            const c = document.getElementById('toastContainer');
            c.innerHTML = '<div class="toast">' + msg + '</div>';
            setTimeout(() => { c.innerHTML = ''; }, 2000);
        }

        // ============================================
        // STATS
        // ============================================
        function updateStats() {
            document.getElementById('diaryCount').textContent = appData.diary.length;
            document.getElementById('inspectionCount').textContent = appData.inspections.length;
            document.getElementById('ncrCount').textContent = appData.ncrs.filter(n => n.status === 'open').length;
            document.getElementById('instructionCount').textContent = appData.instructions.length;
            document.getElementById('photoCount').textContent = mediaStore.length;
        }

        // ============================================
        // RENDERERS
        // ============================================
        function renderDiary(filter = '') {
            const container = document.getElementById('diaryEntries');
            let entries = appData.diary;
            if (filter) {
                const q = filter.toLowerCase();
                entries = entries.filter(e =>
                    e.title.toLowerCase().includes(q) || e.description.toLowerCase().includes(q) ||
                    e.location.toLowerCase().includes(q) || (e.activityType && e.activityType.toLowerCase().includes(q))
                );
            }
            entries.sort((a, b) => new Date(b.timestamp) - new Date(a.timestamp));
            if (!entries.length) {
                container.innerHTML = '<div class="empty-state"><div class="icon">📔</div><p>No diary entries yet</p><p style="font-size:0.75rem;">Tap + to log your first site observation</p></div>';
                return;
            }
            container.innerHTML = entries.map(e => {
                let activityBadge = '';
                if (e.activityType) {
                    const colors = { 'Work in Progress': 'badge-info', 'Material Delivery': 'badge-pending', 'Inspection': 'badge-pass', 'Meeting': 'badge-pending', 'Delay/Issue': 'badge-fail', 'General': 'badge-closed' };
                    activityBadge = '<span class="badge ' + (colors[e.activityType] || 'badge-info') + '">' + e.activityType + '</span>';
                }
                const entryMedia = mediaStore.filter(m => m.entryId === e.id);
                return '<div class="entry-card diary-card">' +
                    '<div class="entry-header"><span class="entry-title">📔 ' + e.title + '</span>' + activityBadge + '</div>' +
                    '<div class="entry-meta"><span>🕐 ' + timeFormat(e.timestamp) + '</span><span>📍 ' + e.location + '</span><span>🌤️ ' + (e.weather || 'N/A') + '</span></div>' +
                    '<div class="entry-desc">' + e.description.replace(/\n/g, '<br>') + '</div>' +
                    (entryMedia.length > 0 ? '<div class="entry-section"><div class="section-label">📸 Media (' + entryMedia.length + ')</div><div class="media-grid">' +
                        entryMedia.map(m => '<div class="media-thumb" onclick="viewMedia(\'' + m.id + '\')">' +
                            (m.type === 'video' || m.type === 'video-large' ? '<div class="placeholder">🎬</div>' : '<img src="' + (m.dataUrl || '') + '" alt="media">') +
                            (m.type === 'video' || m.type === 'video-large' ? '<span class="media-badge">🎬</span>' : '') +
                        '</div>').join('') +
                    '</div></div>' : '') +
                    (e.labourCount || e.equipmentUsed ? '<div class="entry-section"><div class="section-label">Resources on Site</div>' + (e.labourCount ? '👷 Labour: ' + e.labourCount + '<br>' : '') + (e.equipmentUsed ? '🚜 Equipment: ' + e.equipmentUsed : '') + '</div>' : '') +
                    (e.materialsDelivered ? '<div class="entry-section"><div class="section-label">Materials Delivered</div>' + e.materialsDelivered.replace(/\n/g, '<br>') + '</div>' : '') +
                    (e.issuesIdentified ? '<div class="entry-section" style="border-left:3px solid var(--red);"><div class="section-label">⚠️ Issues / Concerns</div>' + e.issuesIdentified.replace(/\n/g, '<br>') + '</div>' : '') +
                    '<div style="margin-top:8px;display:flex;gap:6px;flex-wrap:wrap;">' +
                        '<button class="btn btn-small btn-secondary" onclick="addMediaToEntry(\'' + e.id + '\')">📸 Add Media</button>' +
                        '<button class="btn btn-small btn-primary" onclick="editDiary(\'' + e.id + '\')">✏️ Edit</button>' +
                        '<button class="btn btn-small btn-secondary" onclick="deleteEntry(\'diary\',\'' + e.id + '\')">🗑️</button>' +
                    '</div></div>';
            }).join('');
        }

        function renderInspections() {
            const container = document.getElementById('inspectionEntries');
            const entries = [...appData.inspections].sort((a, b) => new Date(b.timestamp) - new Date(a.timestamp));
            if (!entries.length) { container.innerHTML = '<div class="empty-state"><div class="icon">✅</div><p>No inspections recorded</p></div>'; return; }
            container.innerHTML = entries.map(e => {
                const entryMedia = mediaStore.filter(m => m.entryId === e.id);
                return '<div class="entry-card inspection-card">' +
                    '<div class="entry-header"><span class="entry-title">✅ ' + e.checklistType + '</span><span class="badge ' + (e.result==='pass'?'badge-pass':'badge-fail') + '">' + e.result.toUpperCase() + '</span></div>' +
                    '<div class="entry-meta"><span>🕐 ' + timeFormat(e.timestamp) + '</span><span>📍 ' + e.location + '</span><span>📋 ' + e.items.filter(i=>i.passed).length + '/' + e.items.length + ' passed</span></div>' +
                    '<div class="entry-section"><div class="section-label">Checklist Items</div>' + e.items.map(i => '<div style="padding:3px 0;font-size:0.75rem;">' + (i.passed?'✅':'❌') + ' ' + i.label + (i.comment?' <span style="color:var(--muted);font-size:0.65rem;">— ' + i.comment + '</span>':'') + '</div>').join('') + '</div>' +
                    (entryMedia.length > 0 ? '<div class="entry-section"><div class="section-label">📸 Media (' + entryMedia.length + ')</div><div class="media-grid">' + entryMedia.map(m => '<div class="media-thumb" onclick="viewMedia(\'' + m.id + '\')">' + (m.type==='video'||m.type==='video-large'?'<div class="placeholder">🎬</div>':'<img src="'+(m.dataUrl||'')+'" alt="media">') + '</div>').join('') + '</div></div>' : '') +
                    (e.notes?'<div class="entry-section"><div class="section-label">Inspector Notes</div>' + e.notes + '</div>':'') +
                    (e.correctiveAction?'<div class="entry-section" style="border-left:3px solid var(--red);"><div class="section-label">Corrective Action Required</div>' + e.correctiveAction + '</div>':'') +
                    '<div style="margin-top:8px;"><button class="btn btn-small btn-secondary" onclick="deleteEntry(\'inspections\',\'' + e.id + '\')">🗑️</button></div></div>';
            }).join('');
        }

        function renderNCRs() {
            const container = document.getElementById('ncrEntries');
            const entries = [...appData.ncrs].sort((a,b) => new Date(b.timestamp) - new Date(a.timestamp));
            if (!entries.length) { container.innerHTML = '<div class="empty-state"><div class="icon">🚨</div><p>No NCRs raised</p></div>'; return; }
            container.innerHTML = entries.map(e => {
                const entryMedia = mediaStore.filter(m => m.entryId === e.id);
                return '<div class="entry-card ncr-card">' +
                    '<div class="entry-header"><span class="entry-title">🚨 NCR-' + e.id.split('-')[1] + ': ' + e.title + '</span><span class="badge ' + (e.status==='open'?'badge-open':e.status==='closed'?'badge-closed':'badge-pending') + '">' + e.status.toUpperCase() + '</span></div>' +
                    '<div class="entry-meta"><span>🕐 ' + timeFormat(e.timestamp) + '</span><span>📍 ' + e.location + '</span><span>⚠️ ' + e.severity + '</span>' + (e.responsibleParty?'<span>🏢 ' + e.responsibleParty + '</span>':'') + '</div>' +
                    '<div class="entry-section"><div class="section-label">Description</div>' + e.description + '</div>' +
                    (entryMedia.length > 0 ? '<div class="entry-section"><div class="section-label">📸 Evidence (' + entryMedia.length + ')</div><div class="media-grid">' + entryMedia.map(m => '<div class="media-thumb" onclick="viewMedia(\'' + m.id + '\')">' + (m.type==='video'||m.type==='video-large'?'<div class="placeholder">🎬</div>':'<img src="'+(m.dataUrl||'')+'" alt="media">') + '</div>').join('') + '</div></div>' : '') +
                    '<div class="entry-section" style="border-left:3px solid var(--yellow);"><div class="section-label">Required Corrective Action</div>' + e.actionRequired + '</div>' +
                    (e.closeoutComment?'<div class="entry-section" style="border-left:3px solid var(--green);"><div class="section-label">Closeout Verification</div>' + e.closeoutComment + '<br><small>Closed: ' + timeFormat(e.closedDate) + '</small></div>':'') +
                    '<div style="margin-top:8px;display:flex;gap:6px;">' + (e.status!=='closed'?'<button class="btn btn-small btn-primary" onclick="closeNCR(\'' + e.id + '\')">✅ Close NCR</button>':'') + '<button class="btn btn-small btn-secondary" onclick="deleteEntry(\'ncrs\',\'' + e.id + '\')">🗑️</button></div></div>';
            }).join('');
        }

        function renderInstructions() {
            const container = document.getElementById('instructionEntries');
            const entries = [...appData.instructions].sort((a,b) => new Date(b.timestamp) - new Date(a.timestamp));
            if (!entries.length) { container.innerHTML = '<div class="empty-state"><div class="icon">📋</div><p>No site instructions issued</p></div>'; return; }
            container.innerHTML = entries.map(e => '<div class="entry-card instruction-card">' +
                '<div class="entry-header"><span class="entry-title">📋 SI-' + e.id.split('-')[1] + '</span><span class="badge ' + (e.status==='acknowledged'?'badge-closed':'badge-open') + '">' + e.status.toUpperCase() + '</span></div>' +
                '<div class="entry-meta"><span>🕐 ' + timeFormat(e.timestamp) + '</span><span>👷 ' + e.issuedTo + '</span><span>📍 ' + e.location + '</span></div>' +
                '<div class="entry-desc">' + e.description.replace(/\n/g,'<br>') + '</div>' +
                (e.reference?'<div class="entry-section"><div class="section-label">Reference</div>' + e.reference + '</div>':'') +
                (e.deadline?'<div class="entry-section"><div class="section-label">Deadline</div>⏰ ' + e.deadline + '</div>':'') +
                '<div style="margin-top:8px;display:flex;gap:6px;">' + (e.status!=='acknowledged'?'<button class="btn btn-small btn-primary" onclick="acknowledgeSI(\'' + e.id + '\')">✍️ Ack</button>':'') + '<button class="btn btn-small btn-secondary" onclick="deleteEntry(\'instructions\',\'' + e.id + '\')">🗑️</button></div></div>').join('');
        }

        function renderPhotos() {
            const container = document.getElementById('photoGallery');
            if (!mediaStore.length) {
                container.innerHTML = '<div class="empty-state"><div class="icon">📸</div><p>No media captured</p><p style="font-size:0.75rem;">Add photos/videos from diary, inspections, or NCRs</p></div>';
                return;
            }
            container.innerHTML = '' +
                '<div style="display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap;">' +
                    '<button class="btn btn-small btn-primary" onclick="triggerCamera()">📷 Camera</button>' +
                    '<button class="btn btn-small btn-secondary" onclick="triggerGallery()">🖼️ Gallery</button>' +
                    '<button class="btn btn-small btn-whatsapp" onclick="shareMediaGallery()">📤 Share</button>' +
                '</div>' +
                '<div class="media-grid">' +
                    [...mediaStore].reverse().map(m => '<div class="media-thumb" onclick="viewMedia(\'' + m.id + '\')">' +
                        (m.type === 'video' || m.type === 'video-large' ? '<div class="placeholder">🎬</div>' : '<img src="' + (m.dataUrl || '') + '" alt="media" loading="lazy">') +
                        '<span class="media-badge">' + (m.type === 'video' || m.type === 'video-large' ? '🎬' : '📷') + '</span>' +
                    '</div>').join('') +
                '</div>';
        }

        function renderReport() {
            const today = getToday();
            const container = document.getElementById('reportContent');
            const diaryToday = appData.diary.filter(e => e.timestamp.startsWith(today));
            const inspectionsToday = appData.inspections.filter(e => e.timestamp.startsWith(today));
            const ncrsOpen = appData.ncrs.filter(e => e.status === 'open');
            const ncrsToday = appData.ncrs.filter(e => e.timestamp.startsWith(today));
            const instructionsToday = appData.instructions.filter(e => e.timestamp.startsWith(today));
            const projectName = document.getElementById('projectName').value || 'Project Name';
            const contractNo = document.getElementById('contractNo').value || 'N/A';
            const contractorName = document.getElementById('contractorName').value || 'N/A';
            const reportNo = document.getElementById('reportNo').value || 'COW-001';
            const weather = document.getElementById('weatherSelect').value || 'N/A';
            const temperature = document.getElementById('temperature').value || 'N/A';
            const reportDate = new Date().toLocaleDateString('en-KE', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });

            let report = '';
            report += '═══════════════════════════════════════════════\n';
            report += '  CLERK OF WORKS — DAILY SITE REPORT\n';
            report += '═══════════════════════════════════════════════\n\n';
            report += 'REPORT NO:     ' + reportNo + '\n';
            report += 'DATE:          ' + reportDate + '\n';
            report += 'PROJECT:       ' + projectName + '\n';
            report += 'CONTRACT NO:   ' + contractNo + '\n';
            report += 'CONTRACTOR:    ' + contractorName + '\n';
            report += 'WEATHER:       ' + weather + ' | Temp: ' + temperature + '\n';
            report += 'REPORTED BY:   Clerk of Works\n';
            report += '───────────────────────────────────────────────\n\n';

            report += '1. WORK PROGRESS & OBSERVATIONS\n';
            report += '───────────────────────────────────────────────\n';
            if (diaryToday.length > 0) {
                diaryToday.forEach((e, i) => {
                    report += '\n1.' + (i+1) + ' ' + e.title + ' [' + (e.activityType || 'General') + ']\n';
                    report += '    Location: ' + e.location + '\n';
                    report += '    Time: ' + timeFormat(e.timestamp) + '\n';
                    report += '    ' + e.description.replace(/\n/g, '\n    ') + '\n';
                    if (e.labourCount) report += '    Labour on Site: ' + e.labourCount + '\n';
                    if (e.equipmentUsed) report += '    Equipment: ' + e.equipmentUsed + '\n';
                    if (e.materialsDelivered) report += '    Materials Delivered:\n    ' + e.materialsDelivered.replace(/\n/g, '\n    ') + '\n';
                    if (e.issuesIdentified) report += '    ⚠️ ISSUES: ' + e.issuesIdentified.replace(/\n/g, '\n    ') + '\n';
                    const entryMedia = mediaStore.filter(m => m.entryId === e.id);
                    if (entryMedia.length > 0) report += '    📸 Media: ' + entryMedia.length + ' file(s) attached\n';
                });
            } else { report += '\n    No diary entries recorded for today.\n'; }

            report += '\n\n2. INSPECTIONS & TESTS\n';
            report += '───────────────────────────────────────────────\n';
            if (inspectionsToday.length > 0) {
                inspectionsToday.forEach((e, i) => {
                    report += '\n2.' + (i+1) + ' ' + e.checklistType + ' — RESULT: ' + e.result.toUpperCase() + '\n';
                    report += '    Location: ' + e.location + ' | Time: ' + timeFormat(e.timestamp) + '\n';
                    e.items.forEach(item => {
                        report += '    ' + (item.passed ? '✅' : '❌') + ' ' + item.label;
                        if (item.comment) report += ' (' + item.comment + ')';
                        report += '\n';
                    });
                    if (e.notes) report += '    Notes: ' + e.notes + '\n';
                    if (e.correctiveAction) report += '    ⚠️ Corrective Action: ' + e.correctiveAction + '\n';
                });
            } else { report += '\n    No inspections recorded for today.\n'; }

            report += '\n\n3. NON-CONFORMANCE REPORTS (NCRs)\n';
            report += '───────────────────────────────────────────────\n';
            if (ncrsToday.length > 0) {
                report += '\n   NCRs RAISED TODAY:\n';
                ncrsToday.forEach(e => { report += '\n   NCR-' + e.id.split('-')[1] + ': ' + e.title + ' [' + e.severity + ']\n   Location: ' + e.location + '\n   ' + e.description + '\n   Action: ' + e.actionRequired + '\n   Status: ' + e.status.toUpperCase() + '\n'; });
            }
            if (ncrsOpen.length > 0) {
                report += '\n   OUTSTANDING NCRs (' + ncrsOpen.length + '):\n';
                ncrsOpen.forEach(e => { report += '   • NCR-' + e.id.split('-')[1] + ': ' + e.title + ' [' + e.severity + '] — ' + e.location + '\n'; });
            }
            if (ncrsToday.length === 0 && ncrsOpen.length === 0) { report += '\n    No NCRs raised today. No outstanding NCRs.\n'; }

            report += '\n\n4. SITE INSTRUCTIONS\n───────────────────────────────────────────────\n';
            if (instructionsToday.length > 0) {
                instructionsToday.forEach(e => { report += '\n   SI-' + e.id.split('-')[1] + ': ' + e.issuedTo + '\n   ' + e.description + '\n   Status: ' + e.status.toUpperCase() + '\n'; });
            } else { report += '\n    No site instructions issued today.\n'; }

            report += '\n\n5. PLANT & EQUIPMENT ON SITE\n───────────────────────────────────────────────\n';
            const eq = diaryToday.filter(e => e.equipmentUsed).map(e => e.equipmentUsed);
            report += eq.length > 0 ? '\n    ' + [...new Set(eq.join(', ').split(', '))].join('\n    ') + '\n' : '\n    Refer to diary entries.\n';

            report += '\n\n6. LABOUR ON SITE\n───────────────────────────────────────────────\n';
            const lab = diaryToday.filter(e => e.labourCount);
            lab.length > 0 ? lab.forEach(e => { report += '\n    ' + e.labourCount + ' — ' + e.location + '\n'; }) : report += '\n    Refer to contractor daily labour returns.\n';

            report += '\n\n7. MATERIALS DELIVERED\n───────────────────────────────────────────────\n';
            const mat = diaryToday.filter(e => e.materialsDelivered);
            mat.length > 0 ? mat.forEach(e => { report += '\n    ' + e.materialsDelivered.replace(/\n/g, '\n    ') + '\n'; }) : report += '\n    No major material deliveries recorded.\n';

            report += '\n\n8. HEALTH & SAFETY OBSERVATIONS\n───────────────────────────────────────────────\n';
            report += '\n    Site appeared orderly. All personnel observed wearing mandatory PPE.\n';
            report += '    No lost-time incidents reported.\n';

            report += '\n\n9. GENERAL REMARKS\n───────────────────────────────────────────────\n';
            report += '\n    Work progressing per approved programme.\n';

            report += '\n\n═══════════════════════════════════════════════\n';
            report += '  REPORT END — ' + reportDate + '\n';
            report += '═══════════════════════════════════════════════\n';
            report += '\n  SIGNED: ................................    DATE: ................\n';
            report += '  Clerk of Works\n';
            report += '\n  COUNTERSIGNED: .........................    DATE: ................\n';
            report += '  Contractor\'s Representative\n';

            container.innerHTML = '' +
                '<div style="display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap;">' +
                    '<button class="btn btn-small btn-primary" onclick="copyReport()">📋 Copy</button>' +
                    '<button class="btn btn-small btn-secondary" onclick="printReport()">🖨️ Print</button>' +
                    '<button class="btn btn-small btn-whatsapp" onclick="shareReportWhatsApp()">📱 WhatsApp</button>' +
                    '<button class="btn btn-small btn-secondary" onclick="shareReport()">📤 Share</button>' +
                    '<button class="btn btn-small btn-secondary" onclick="saveReport()">💾 Save</button>' +
                '</div>' +
                '<div style="display:flex;gap:8px;margin-bottom:8px;flex-wrap:wrap;">' +
                    '<span class="badge badge-info">Diary: ' + diaryToday.length + '</span>' +
                    '<span class="badge ' + (inspectionsToday.filter(i=>i.result==='fail').length>0?'badge-fail':'badge-pass') + '">Insp: ' + inspectionsToday.length + '</span>' +
                    '<span class="badge badge-open">NCRs: ' + ncrsOpen.length + '</span>' +
                '</div>' +
                '<div class="report-preview" id="reportText">' + report + '</div>';
            window._currentReport = report;
        }

        function renderAll() {
            renderDiary();
            renderInspections();
            renderNCRs();
            renderInstructions();
            renderPhotos();
            updateStats();
        }

        // ============================================
        // MODAL
        // ============================================
        function showModal(title, formHTML, onSubmit) {
            const container = document.getElementById('modalContainer');
            container.innerHTML = '' +
                '<div class="modal-overlay" id="modalOverlay"><div class="modal">' +
                    '<h2>' + title + '</h2>' +
                    '<div id="modalForm">' + formHTML + '</div>' +
                    '<div class="btn-row">' +
                        '<button class="btn btn-secondary" onclick="closeModal()">Cancel</button>' +
                        '<button class="btn btn-primary" id="modalSubmit">Save Entry</button>' +
                    '</div>' +
                '</div></div>';
            document.getElementById('modalSubmit').addEventListener('click', () => {
                const result = onSubmit();
                if (result !== false) { closeModal(); renderAll(); showToast('✅ Saved!'); }
            });
            document.getElementById('modalOverlay').addEventListener('click', (e) => { if (e.target.id === 'modalOverlay') closeModal(); });
        }

        function closeModal() { document.getElementById('modalContainer').innerHTML = ''; }

        // ============================================
        // FORMS
        // ============================================
        function showDiaryForm(editId = null) {
            const existing = editId ? appData.diary.find(e => e.id === editId) : null;
            const formHTML = '' +
                '<div class="form-group"><label>Entry Title *</label><input type="text" id="diaryTitle" placeholder="e.g., Concreting — 3rd Floor Slab" value="' + (existing ? existing.title : '') + '"></div>' +
                '<div class="form-group"><label>Activity Type</label><select id="diaryActivity"><option>Work in Progress</option><option>Material Delivery</option><option>Inspection</option><option>Meeting</option><option>Delay/Issue</option><option>General</option></select></div>' +
                '<div class="form-group"><label>Location</label><input type="text" id="diaryLocation" placeholder="e.g., Block A, Floor 3" value="' + (existing ? existing.location : '') + '"></div>' +
                '<div class="form-group"><label>Detailed Description *</label><textarea id="diaryDesc" placeholder="Describe work observed...">' + (existing ? existing.description : '') + '</textarea></div>' +
                '<div class="form-group"><label>Labour on Site</label><input type="text" id="diaryLabour" value="' + (existing ? existing.labourCount || '' : '') + '"></div>' +
                '<div class="form-group"><label>Equipment on Site</label><input type="text" id="diaryEquipment" value="' + (existing ? existing.equipmentUsed || '' : '') + '"></div>' +
                '<div class="form-group"><label>Materials Delivered</label><textarea id="diaryMaterials" style="min-height:60px;">' + (existing ? existing.materialsDelivered || '' : '') + '</textarea></div>' +
                '<div class="form-group"><label>Issues / Concerns</label><textarea id="diaryIssues" style="min-height:60px;">' + (existing ? existing.issuesIdentified || '' : '') + '</textarea></div>' +
                '<div class="form-group"><label>Contractor Personnel</label><input type="text" id="diaryContractorRep" value="' + (existing ? existing.contractorOnSite || '' : '') + '"></div>' +
                '<div class="form-group"><label>📸 Photos / Videos</label>' +
                    '<div class="media-actions">' +
                        '<button type="button" class="btn btn-secondary" onclick="triggerCamera()">📷 Take Photo</button>' +
                        '<button type="button" class="btn btn-secondary" onclick="triggerGallery()">🖼️ Upload</button>' +
                    '</div>' +
                    '<div id="mediaPreviewContainer" style="margin-top:8px;"></div>' +
                '</div>';

            pendingMedia = [];
            showModal(existing ? '✏️ Edit Diary Entry' : '📔 New Diary Entry', formHTML, () => {
                const title = document.getElementById('diaryTitle').value.trim();
                const description = document.getElementById('diaryDesc').value.trim();
                if (!title || !description) { alert('Title and description required'); return false; }
                const entry = {
                    id: existing ? existing.id : genId('diary'), title,
                    activityType: document.getElementById('diaryActivity').value,
                    location: document.getElementById('diaryLocation').value, description,
                    labourCount: document.getElementById('diaryLabour').value,
                    equipmentUsed: document.getElementById('diaryEquipment').value,
                    materialsDelivered: document.getElementById('diaryMaterials').value,
                    issuesIdentified: document.getElementById('diaryIssues').value,
                    contractorOnSite: document.getElementById('diaryContractorRep').value,
                    weather: document.getElementById('weatherSelect').value,
                    temperature: document.getElementById('temperature').value,
                    timestamp: existing ? existing.timestamp : new Date().toISOString(),
                    updatedAt: new Date().toISOString()
                };
                if (existing) {
                    const idx = appData.diary.findIndex(e => e.id === editId);
                    if (idx > -1) appData.diary[idx] = entry;
                } else {
                    appData.diary.push(entry);
                }
                savePendingMedia(entry.id);
                saveData(appData);
            });

            if (existing && existing.activityType) {
                setTimeout(() => { const sel = document.getElementById('diaryActivity'); if (sel) sel.value = existing.activityType; }, 100);
            }
            setTimeout(renderMediaPreview, 200);
        }

        function editDiary(id) { showDiaryForm(id); }

        function showInspectionForm() {
            const checklists = {
                'Concrete Pour — Pre-Pour': ['Formwork checked', 'Reinforcement as per drawings', 'Cover blocks placed', 'Grade confirmed', 'Slump test done', 'Vibrators ready', 'Curing plan ready', 'Pour card signed'],
                'Steel Reinforcement': ['Bar sizes correct', 'Spacing within tolerance', 'Lap lengths correct', 'Couplers torqued', 'Chairs placed', 'Clean & rust-free', 'Drawings on site'],
                'Blockwork / Masonry': ['Block type correct', 'Mortar 1:4', 'Plumb & level', 'Wall ties installed', 'DPC in place', 'Openings correct', 'Joints filled'],
                'Excavation': ['Setting out checked', 'Depth correct', 'Bottom firm', 'Safety batter', 'Dewatering', 'Blinding approval'],
                'Waterproofing': ['Surface prepared', 'Primer applied', 'Membrane lapped', 'Detailing correct', 'Protection board', 'Ponding test'],
                'Plastering': ['Background prepared', 'Mesh at joints', 'Screeds in place', 'Mix ratio correct', 'Thickness OK', 'Curing done'],
            };
            window._inspectionChecklists = checklists;
            let formHTML = '<div class="form-group"><label>Checklist Type *</label><select id="checklistType" onchange="window.updateChecklistItems()"><option value="">— Select —</option>';
            Object.keys(checklists).forEach(k => { formHTML += '<option value="' + k + '">' + k + '</option>'; });
            formHTML += '</select></div>';
            formHTML += '<div class="form-group"><label>Location</label><input type="text" id="inspectionLocation" value="Block A, Floor 3"></div>';
            formHTML += '<div class="form-group"><label>Checklist Items</label><div id="checklistItems" style="background:var(--bg);border-radius:8px;padding:4px 12px;border:1px solid var(--border);"><p style="color:var(--muted);text-align:center;padding:16px;">Select checklist type</p></div></div>';
            formHTML += '<div class="form-group"><label>Inspector Notes</label><textarea id="inspectionNotes"></textarea></div>';
            formHTML += '<div class="form-group"><label>Corrective Actions</label><textarea id="inspectionCorrective"></textarea></div>';
            formHTML += '<div class="form-group"><label>📸 Photos / Videos</label><div class="media-actions"><button type="button" class="btn btn-secondary" onclick="triggerCamera()">📷 Take Photo</button><button type="button" class="btn btn-secondary" onclick="triggerGallery()">🖼️ Upload</button></div><div id="mediaPreviewContainer" style="margin-top:8px;"></div></div>';

            pendingMedia = [];
            showModal('✅ Inspection Checklist', formHTML, () => {
                const type = document.getElementById('checklistType').value;
                if (!type) { alert('Select checklist type'); return false; }
                const cbs = document.querySelectorAll('#checklistItems input[type="checkbox"]');
                const comments = document.querySelectorAll('#checklistItems .item-comment');
                const items = Array.from(cbs).map((cb, i) => ({ label: cb.nextElementSibling.textContent.replace(/\s*$/, ''), passed: cb.checked, comment: comments[i] ? comments[i].value : '' }));
                const entry = { id: genId('insp'), checklistType: type, location: document.getElementById('inspectionLocation').value, items, result: items.every(i => i.passed) ? 'pass' : 'fail', notes: document.getElementById('inspectionNotes').value, correctiveAction: document.getElementById('inspectionCorrective').value, timestamp: new Date().toISOString() };
                appData.inspections.push(entry);
                savePendingMedia(entry.id);
                saveData(appData);
            });
            window.updateChecklistItems = function() {
                const type = document.getElementById('checklistType').value;
                const container = document.getElementById('checklistItems');
                if (!type || !window._inspectionChecklists[type]) { container.innerHTML = '<p style="color:var(--muted);text-align:center;padding:16px;">Select checklist type</p>'; return; }
                container.innerHTML = window._inspectionChecklists[type].map((item, i) => '<div class="checklist-item"><input type="checkbox" id="item' + i + '" checked><label for="item' + i + '" style="flex:1;">' + item + '</label><input type="text" class="item-comment" placeholder="Comment" style="width:35%;padding:4px 8px;font-size:0.7rem;background:transparent;border:1px solid var(--border);border-radius:4px;color:var(--text);"></div>').join('');
            };
            setTimeout(renderMediaPreview, 200);
        }

        function showNCRForm() {
            const formHTML = '' +
                '<div class="form-group"><label>NCR Title *</label><input type="text" id="ncrTitle" placeholder="e.g., Honeycomb on Column C12"></div>' +
                '<div class="form-group"><label>Severity</label><select id="ncrSeverity"><option value="Minor">Minor</option><option value="Major" selected>Major</option><option value="Critical">Critical</option></select></div>' +
                '<div class="form-group"><label>Location</label><input type="text" id="ncrLocation" value="Block A, Floor 3"></div>' +
                '<div class="form-group"><label>Responsible Party</label><input type="text" id="ncrResponsible"></div>' +
                '<div class="form-group"><label>Description *</label><textarea id="ncrDesc"></textarea></div>' +
                '<div class="form-group"><label>Required Action *</label><textarea id="ncrAction"></textarea></div>' +
                '<div class="form-group"><label>📸 Evidence</label><div class="media-actions"><button type="button" class="btn btn-secondary" onclick="triggerCamera()">📷 Take Photo</button><button type="button" class="btn btn-secondary" onclick="triggerGallery()">🖼️ Upload</button></div><div id="mediaPreviewContainer" style="margin-top:8px;"></div></div>';
            pendingMedia = [];
            showModal('🚨 Raise NCR', formHTML, () => {
                const title = document.getElementById('ncrTitle').value.trim();
                const desc = document.getElementById('ncrDesc').value.trim();
                const action = document.getElementById('ncrAction').value.trim();
                if (!title || !desc || !action) { alert('All fields required'); return false; }
                const entry = { id: genId('ncr'), title, severity: document.getElementById('ncrSeverity').value, location: document.getElementById('ncrLocation').value, responsibleParty: document.getElementById('ncrResponsible').value, description: desc, actionRequired: action, status: 'open', timestamp: new Date().toISOString() };
                appData.ncrs.push(entry);
                savePendingMedia(entry.id);
                saveData(appData);
            });
            setTimeout(renderMediaPreview, 200);
        }

        function showInstructionForm() {
            const formHTML = '' +
                '<div class="form-group"><label>Issued To *</label><input type="text" id="siTo"></div>' +
                '<div class="form-group"><label>Location</label><input type="text" id="siLocation" value="Block A, Floor 3"></div>' +
                '<div class="form-group"><label>Instruction *</label><textarea id="siDesc"></textarea></div>' +
                '<div class="form-group"><label>Reference</label><input type="text" id="siRef"></div>' +
                '<div class="form-group"><label>Deadline</label><input type="text" id="siDeadline" placeholder="e.g., 18 June 2026"></div>';
            showModal('📋 Site Instruction', formHTML, () => {
                const to = document.getElementById('siTo').value.trim();
                const desc = document.getElementById('siDesc').value.trim();
                if (!to || !desc) { alert('All fields required'); return false; }
                appData.instructions.push({ id: genId('si'), issuedTo: to, location: document.getElementById('siLocation').value, description: desc, reference: document.getElementById('siRef').value, deadline: document.getElementById('siDeadline').value, status: 'issued', timestamp: new Date().toISOString() });
                saveData(appData);
            });
        }

        function addMediaToEntry(entryId) {
            pendingMedia = [];
            pendingMediaForEntry = entryId;
            const container = document.getElementById('modalContainer');
            container.innerHTML = '' +
                '<div class="modal-overlay" id="modalOverlay"><div class="modal">' +
                    '<h2>📸 Add Media</h2>' +
                    '<div class="media-actions">' +
                        '<button class="btn btn-primary" onclick="triggerCamera()">📷 Take Photo</button>' +
                        '<button class="btn btn-secondary" onclick="triggerGallery()">🖼️ Upload from Gallery</button>' +
                    '</div>' +
                    '<div id="mediaPreviewContainer" style="margin-top:12px;"></div>' +
                    '<div class="btn-row"><button class="btn btn-secondary" onclick="closeModal()">Cancel</button><button class="btn btn-primary" onclick="saveMediaToEntry(\'' + entryId + '\')">Save Media</button></div>' +
                '</div></div>';
            document.getElementById('modalOverlay').addEventListener('click', (e) => { if (e.target.id === 'modalOverlay') closeModal(); });
            renderMediaPreview();
        }

        function saveMediaToEntry(entryId) {
            savePendingMedia(entryId);
            closeModal();
            renderAll();
            showToast('📸 Media added!');
        }

        function showFABMenu() {
            const container = document.getElementById('modalContainer');
            container.innerHTML = '' +
                '<div class="modal-overlay" id="fabOverlay" style="align-items:flex-end;justify-content:center;">' +
                    '<div class="modal" style="text-align:center;max-width:400px;">' +
                        '<h2 style="justify-content:center;">➕ Add New</h2>' +
                        '<button class="btn btn-primary" style="margin-bottom:8px;width:100%;" onclick="closeModal();showDiaryForm();">📔 Diary Entry</button>' +
                        '<button class="btn btn-primary" style="margin-bottom:8px;width:100%;background:var(--green);" onclick="closeModal();showInspectionForm();">✅ Inspection</button>' +
                        '<button class="btn btn-primary" style="margin-bottom:8px;width:100%;background:var(--red);" onclick="closeModal();showNCRForm();">🚨 Raise NCR</button>' +
                        '<button class="btn btn-primary" style="margin-bottom:8px;width:100%;background:var(--yellow);color:#0d1117;" onclick="closeModal();showInstructionForm();">📋 Site Instruction</button>' +
                        '<button class="btn btn-primary" style="margin-bottom:8px;width:100%;background:var(--purple);" onclick="closeModal();triggerCamera();">📷 Quick Photo</button>' +
                        '<button class="btn btn-secondary" style="width:100%;" onclick="closeModal();">Cancel</button>' +
                    '</div></div>';
            document.getElementById('fabOverlay').addEventListener('click', e => { if (e.target.id === 'fabOverlay') closeModal(); });
        }

        // ============================================
        // ACTIONS
        // ============================================
        function deleteEntry(type, id) {
            if (!confirm('Delete this entry?')) return;
            appData[type] = appData[type].filter(e => e.id !== id);
            mediaStore = mediaStore.filter(m => m.entryId !== id);
            saveData(appData);
            saveMedia(mediaStore);
            renderAll();
            showToast('🗑️ Deleted');
        }

        function closeNCR(id) {
            const ncr = appData.ncrs.find(n => n.id === id);
            if (!ncr) return;
            const comment = prompt('Closeout verification comment:');
            if (comment === null) return;
            ncr.status = 'closed';
            ncr.closeoutComment = comment;
            ncr.closedDate = new Date().toISOString();
            saveData(appData);
            renderAll();
            showToast('✅ NCR closed');
        }

        function acknowledgeSI(id) {
            const si = appData.instructions.find(s => s.id === id);
            if (!si) return;
            si.status = 'acknowledged';
            si.acknowledgedDate = new Date().toISOString();
            saveData(appData);
            renderAll();
            showToast('✍️ Acknowledged');
        }

        function copyReport() {
            navigator.clipboard.writeText(window._currentReport || '').then(() => showToast('📋 Copied!'));
        }

        function printReport() {
            // Switch to report panel and print
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
            document.querySelector('[data-tab="report"]').classList.add('active');
            document.getElementById('panel-report').classList.add('active');
            renderReport();
            setTimeout(() => window.print(), 300);
        }

        function shareViaWhatsApp(title, text) {
            const encoded = encodeURIComponent(text);
            window.open('https://wa.me/?text=' + encoded, '_blank');
        }

        function shareReportWhatsApp() {
            const report = window._currentReport || '';
            shareViaWhatsApp('COW Daily Report', report);
        }

        function shareReport() {
            const report = window._currentReport || '';
            if (navigator.share) {
                navigator.share({ title: 'COW Daily Report — ' + getToday(), text: report }).catch(() => {});
            } else {
                copyReport();
            }
        }

        function saveReport() {
            const report = window._currentReport || '';
            appData.dailyReports.push({ id: genId('rpt'), reportNo: document.getElementById('reportNo').value, content: report, date: getToday(), timestamp: new Date().toISOString() });
            const current = parseInt((settings.reportCounter || 1));
            settings.reportCounter = current + 1;
            saveSettings(settings);
            document.getElementById('reportNo').value = 'COW-' + String(current + 1).padStart(3, '0');
            saveData(appData);
            showToast('💾 Saved');
        }

        // ============================================
        // INIT
        // ============================================
        function init() {
            document.getElementById('currentDate').textContent = new Date().toLocaleDateString('en-KE', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });

            // Restore settings
            if (settings.projectName) document.getElementById('projectName').value = settings.projectName;
            if (settings.contractNo) document.getElementById('contractNo').value = settings.contractNo;
            if (settings.contractorName) document.getElementById('contractorName').value = settings.contractorName;
            if (settings.reportCounter) document.getElementById('reportNo').value = 'COW-' + String(settings.reportCounter).padStart(3, '0');

            // Settings listeners
            ['projectName','contractNo','contractorName'].forEach(id => {
                const el = document.getElementById(id);
                if (el) el.addEventListener('change', () => { settings[id] = el.value; saveSettings(settings); });
            });

            // Tab switching
            document.querySelectorAll('.tab').forEach(tab => {
                tab.addEventListener('click', () => {
                    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
                    document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
                    tab.classList.add('active');
                    const panel = document.getElementById('panel-' + tab.dataset.tab);
                    if (panel) panel.classList.add('active');
                    if (tab.dataset.tab === 'report') renderReport();
                    if (tab.dataset.tab === 'photos') renderPhotos();
                });
            });

            // FAB
            document.getElementById('fabBtn').addEventListener('click', showFABMenu);

            // Search
            document.getElementById('diarySearch').addEventListener('input', e => renderDiary(e.target.value));

            // File inputs
            document.getElementById('hiddenFileInput').addEventListener('change', async (e) => {
                const files = e.target.files;
                for (let f of files) {
                    await addMediaFromFile(f);
                }
                renderMediaPreview();
                e.target.value = '';
            });

            document.getElementById('hiddenGalleryInput').addEventListener('change', async (e) => {
                const files = e.target.files;
                for (let f of files) {
                    await addMediaFromFile(f);
                }
                renderMediaPreview();
                e.target.value = '';
            });

            renderAll();
        }

        document.addEventListener('DOMContentLoaded', init);
    </script>
</body>
</html>
